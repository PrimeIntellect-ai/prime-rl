ARG BASE_IMAGE=ghcr.io/primeintellect-ai/prime-rl@sha256:4a2713ef9f6df8f002a8e63398f408127c05588e611e655d792252ecfd627ace
FROM ${BASE_IMAGE}

USER root

# Keep Prime main, the pinned NVFP4 runtime, and the cache/package-move fixes
# from the immutable dev3 image. This layer only tracks vLLM's OnlineRenderer
# member rename; it does not install or compile anything.
COPY --chown=appuser:appuser \
    src/prime_rl/inference/vllm/serving_tokens.py \
    /app/src/prime_rl/inference/vllm/serving_tokens.py

USER appuser
