#!/bin/bash

#SBATCH --job-name={{ job_name }}
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gres=gpu:{{ gpus_per_node }}
#SBATCH --exclusive
#SBATCH --partition={{ partition }}
{%- if account %}
#SBATCH --account={{ account }}
{%- endif %}
{%- if time %}
#SBATCH --time={{ time }}
{%- endif %}
{%- if nodelist %}
#SBATCH --nodelist={{ nodelist }}
{%- endif %}
{%- if exclude %}
#SBATCH --exclude={{ exclude }}
{%- endif %}
#SBATCH --output={{ output_dir }}/job_%j.log
#SBATCH --error={{ output_dir }}/job_%j.log

# Exit immediately if any setup command or the launcher fails so the SLURM job
# releases its allocation instead of holding nodes after a crash.
set -e

export PROJECT_DIR={{ project_dir }}

# Setup environment
cd $PROJECT_DIR
[ -f .env ] && source .env
source .venv/bin/activate
# Exclude workspace members the orchestrator subprocess imports from (prime-rl-configs +
# its prime-pydantic-config dep) so concurrent fan-out doesn't race on the shared
# beegfs .venv. Extends the May-26 --no-install-project fix.
uv sync --all-extras --inexact --no-install-project --no-install-package prime-rl-configs --no-install-package prime-pydantic-config

{% if pre_run_command %}
# Pre-run command
{{ pre_run_command }}
{% endif %}
uv run sft @ {{ config_path }}
