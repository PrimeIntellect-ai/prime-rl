#!/bin/bash

#SBATCH --job-name={{ job_name }}
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gres=gpu:{{ gpus_per_node }}
#SBATCH --exclusive
#SBATCH --partition={{ partition }}
{%- if account %}
#SBATCH --account={{ account }}
{%- endif %}
{%- if time %}
#SBATCH --time={{ time }}
{%- endif %}
{%- if nodelist %}
#SBATCH --nodelist={{ nodelist }}
{%- endif %}
{%- if exclude %}
#SBATCH --exclude={{ exclude }}
{%- endif %}
#SBATCH --output={{ output_dir }}/job_%j.log
#SBATCH --error={{ output_dir }}/job_%j.log

export PROJECT_DIR={{ project_dir }}

# Setup environment. Serialize `uv sync` across concurrent jobs that share
# this venv (e.g. parallel sweep trials) so they don't clobber each other's
# installs and leave a half-broken venv behind.
cd $PROJECT_DIR
[ -f .env ] && source .env
source .venv/bin/activate
flock -x $PROJECT_DIR/.uv-sync.lock uv sync --all-extras || { echo "FATAL: uv sync failed" >&2; exit 1; }
# Block uv from implicitly re-syncing during `uv run`, which would race with
# concurrent jobs after the locked sync above already finished.
export UV_NO_SYNC=1

{% if pre_run_command %}
# Pre-run command
{{ pre_run_command }}
{% endif %}
uv run rl @ {{ config_path }}
