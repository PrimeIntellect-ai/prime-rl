#!/bin/bash

#SBATCH --job-name={{ job_name }}
#SBATCH --nodes={{ num_train_nodes + (num_prefill_nodes + num_decode_nodes) * num_infer_replicas }}
#SBATCH --ntasks-per-node=1
#SBATCH --gres=gpu:{{ gpus_per_node }}
#SBATCH --partition={{ partition }}
{%- if account %}
#SBATCH --account={{ account }}
{%- endif %}
{%- if time %}
#SBATCH --time={{ time }}
{%- endif %}
{%- if nodelist %}
#SBATCH --nodelist={{ nodelist }}
{%- endif %}
{%- if exclude %}
#SBATCH --exclude={{ exclude }}
{%- endif %}
#SBATCH --exclusive
#SBATCH --output={{ output_dir }}/job_%j.log
#SBATCH --error={{ output_dir }}/job_%j.log

# Disaggregated P/D deployment config
export NUM_TRAIN_NODES={{ num_train_nodes }}
export NUM_PREFILL_NODES={{ num_prefill_nodes }}
export NUM_DECODE_NODES={{ num_decode_nodes }}
export NUM_INFER_REPLICAS={{ num_infer_replicas }}
export NODES_PER_REPLICA=$((NUM_PREFILL_NODES + NUM_DECODE_NODES))
export TOTAL_INFER_NODES=$((NODES_PER_REPLICA * NUM_INFER_REPLICAS))
export GPUS_PER_NODE={{ gpus_per_node }}
export ROUTER_PORT={{ router_port }}
export PREFILL_PORT={{ prefill_port }}
export DECODE_PORT={{ decode_port }}
export INFERENCE_DATA_PARALLEL_RPC_PORT={{ inference_data_parallel_rpc_port }}

# Paths
export PROJECT_DIR={{ project_dir }}
export CONFIG_DIR={{ config_dir }}
export OUTPUT_DIR={{ output_dir }}
export ORCHESTRATOR_OUTPUT_DIR={{ orchestrator_output_dir }}
mkdir -p $OUTPUT_DIR/slurm

# Clear previous rollouts and broadcast flags
rm -rf $OUTPUT_DIR/run_*/rollouts
rm -rf $OUTPUT_DIR/run_*/broadcasts
rm -rf $OUTPUT_DIR/rollouts

# General
export CUDA_DEVICE_ORDER=PCI_BUS_ID
export PYTHONUNBUFFERED=1
export OMP_NUM_THREADS=1

# Networking
HOSTNAMES=( $( scontrol show hostnames $SLURM_JOB_NODELIST ) )
INFER_HOSTS=( ${HOSTNAMES[@]:0:$TOTAL_INFER_NODES} )
TRAIN_HOSTS=( ${HOSTNAMES[@]:$TOTAL_INFER_NODES:$SLURM_JOB_NUM_NODES} )
export HOSTNAMES_STR="${HOSTNAMES[*]}"

# Build per-replica router URLs (for inference requests) and per-node admin URLs (for weight updates)
INFER_URLS=""
ADMIN_URLS=""

for ((r=0; r<NUM_INFER_REPLICAS; r++)); do
    replica_base=$((r * NODES_PER_REPLICA))
    # Router runs on the first prefill node of each replica
    router_host="${INFER_HOSTS[$replica_base]}"
    if [ -z "$INFER_URLS" ]; then
        INFER_URLS="http://${router_host}:${ROUTER_PORT}/v1"
    else
        INFER_URLS="$INFER_URLS http://${router_host}:${ROUTER_PORT}/v1"
    fi

    # Admin URLs: one per node (prefill nodes then decode nodes)
    for ((p=0; p<NUM_PREFILL_NODES; p++)); do
        node_idx=$((replica_base + p))
        if [ -z "$ADMIN_URLS" ]; then
            ADMIN_URLS="http://${INFER_HOSTS[$node_idx]}:${PREFILL_PORT}"
        else
            ADMIN_URLS="$ADMIN_URLS http://${INFER_HOSTS[$node_idx]}:${PREFILL_PORT}"
        fi
    done
    for ((d=0; d<NUM_DECODE_NODES; d++)); do
        node_idx=$((replica_base + NUM_PREFILL_NODES + d))
        if [ -z "$ADMIN_URLS" ]; then
            ADMIN_URLS="http://${INFER_HOSTS[$node_idx]}:${DECODE_PORT}"
        else
            ADMIN_URLS="$ADMIN_URLS http://${INFER_HOSTS[$node_idx]}:${DECODE_PORT}"
        fi
    done
done

export INFER_URLS
export ADMIN_URLS
echo "HOSTNAMES=${HOSTNAMES[*]}"
echo "TRAIN_HOSTS=${TRAIN_HOSTS[*]}"
echo "INFER_HOSTS=${INFER_HOSTS[*]}"
echo "INFER_URLS=${INFER_URLS}"
echo "ADMIN_URLS=${ADMIN_URLS}"

export MASTER_ADDR="${HOSTNAMES[$TOTAL_INFER_NODES]}"
export MASTER_PORT=29500
echo "MASTER_ADDR=${MASTER_ADDR}"
echo "MASTER_PORT=${MASTER_PORT}"

# Setup environment
cd $PROJECT_DIR
[ -f .env ] && source .env
source .venv/bin/activate
uv sync --all-extras --group fp8-inference

{% if pre_run_command %}
# Pre-run command
{{ pre_run_command }}
{% endif %}

# Run RL
srun bash -c '
    # Source environment
    cd $PROJECT_DIR
    [ -f .env ] && source .env
    source .venv/bin/activate

    # Higher ulimit
    ulimit -n 65536
    export GIT_LFS_SKIP_SMUDGE=1

    # Infiniband setup
    IB_HCA=$(ibv_devinfo 2>/dev/null | sed -n -e "/hca_id/p" -e "/link_layer:/p" | grep -B1 InfiniBand | grep hca_id | sed -e "s/^hca_id://g" | tr -d "[[:blank:]]" | paste -sd,)
    export NCCL_IB_HCA=$IB_HCA

    # DeepEP / NIXL environment
    export DEEPEP_NVSHMEM_DISABLE=0
    export NVSHMEM_DISABLE_CUDA_VMM=1
    export NVSHMEM_BOOTSTRAP_UID_SOCK_IFNAME=eth0

    # Reconstruct hostnames array from exported string (bash arrays cannot be exported)
    read -ra HOSTNAMES <<< "$HOSTNAMES_STR"

if [ "$SLURM_PROCID" -lt "$TOTAL_INFER_NODES" ]; then
    export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:False"
    INFER_NODE_RANK=$SLURM_PROCID
    export VLLM_WORKER_MULTIPROC_METHOD=spawn

    # Determine which replica this node belongs to
    REPLICA_IDX=$((INFER_NODE_RANK / NODES_PER_REPLICA))
    RANK_IN_REPLICA=$((INFER_NODE_RANK % NODES_PER_REPLICA))

    # Determine if this is a prefill or decode node
    if [ "$RANK_IN_REPLICA" -lt "$NUM_PREFILL_NODES" ]; then
        ROLE="prefill"
        ROLE_PORT=$PREFILL_PORT
        RANK_IN_ROLE=$RANK_IN_REPLICA
    else
        ROLE="decode"
        ROLE_PORT=$DECODE_PORT
        RANK_IN_ROLE=$((RANK_IN_REPLICA - NUM_PREFILL_NODES))
    fi

    echo "Node $INFER_NODE_RANK: replica=$REPLICA_IDX role=$ROLE rank_in_role=$RANK_IN_ROLE port=$ROLE_PORT"

    # Launch vllm-router on the first prefill node of each replica
    if [ "$ROLE" = "prefill" ] && [ "$RANK_IN_ROLE" -eq 0 ]; then
        REPLICA_BASE=$((REPLICA_IDX * NODES_PER_REPLICA))

        # Build prefill and decode server URLs for the router
        PREFILL_SERVERS=""
        for ((p=0; p<NUM_PREFILL_NODES; p++)); do
            node_idx=$((REPLICA_BASE + p))
            host="${HOSTNAMES[$node_idx]}"
            if [ -z "$PREFILL_SERVERS" ]; then
                PREFILL_SERVERS="http://${host}:${PREFILL_PORT}"
            else
                PREFILL_SERVERS="${PREFILL_SERVERS},http://${host}:${PREFILL_PORT}"
            fi
        done

        DECODE_SERVERS=""
        for ((d=0; d<NUM_DECODE_NODES; d++)); do
            node_idx=$((REPLICA_BASE + NUM_PREFILL_NODES + d))
            host="${HOSTNAMES[$node_idx]}"
            if [ -z "$DECODE_SERVERS" ]; then
                DECODE_SERVERS="http://${host}:${DECODE_PORT}"
            else
                DECODE_SERVERS="${DECODE_SERVERS},http://${host}:${DECODE_PORT}"
            fi
        done

        echo "Starting vllm-router for replica $REPLICA_IDX: prefill=$PREFILL_SERVERS decode=$DECODE_SERVERS"
        vllm-router-rs \
            --port $ROUTER_PORT \
            --service-discovery static \
            --static-backends "$PREFILL_SERVERS" \
            --static-decode-backends "$DECODE_SERVERS" \
            --engine-stats-interval 5 \
            2>&1 | tee $OUTPUT_DIR/slurm/latest_router_replica_${REPLICA_IDX}.log $OUTPUT_DIR/slurm/job_${SLURM_JOB_ID}_router_replica_${REPLICA_IDX}.log &
    fi

    # Build vLLM extra args for disaggregated mode
    # vLLM uses kv_producer/kv_consumer (not prefill/decode)
    if [ "$ROLE" = "prefill" ]; then
        KV_ROLE="kv_producer"
    else
        KV_ROLE="kv_consumer"
    fi
    VLLM_EXTRA="{\"kv_transfer_config\": {\"kv_connector\": \"NixlConnector\", \"kv_role\": \"$KV_ROLE\", \"kv_parallel_size\": 1}}"

    uv run inference \
        @ $CONFIG_DIR/inference.toml \
        --server.port $ROLE_PORT \
        --data-parallel-rpc-port $INFERENCE_DATA_PARALLEL_RPC_PORT \
        --vllm-extra "$VLLM_EXTRA" \
        2>&1 | tee $OUTPUT_DIR/slurm/latest_infer_${ROLE}_replica_${REPLICA_IDX}_rank_${RANK_IN_ROLE}.log $OUTPUT_DIR/slurm/job_${SLURM_JOB_ID}_infer_${ROLE}_replica_${REPLICA_IDX}_rank_${RANK_IN_ROLE}.log

else
    TRAIN_NODE_RANK=$((SLURM_PROCID - TOTAL_INFER_NODES))

    if [ "$TRAIN_NODE_RANK" -eq 0 ]; then
        ORCHESTRATOR_ARGS="@ $CONFIG_DIR/orchestrator.toml"
        ORCHESTRATOR_ARGS="$ORCHESTRATOR_ARGS --client.base-url $INFER_URLS"
        ORCHESTRATOR_ARGS="$ORCHESTRATOR_ARGS --client.admin-base-url $ADMIN_URLS"
        {% if weight_broadcast_type == "nccl" %}ORCHESTRATOR_ARGS="$ORCHESTRATOR_ARGS --weight_broadcast.host $MASTER_ADDR"
        {% endif %}uv run orchestrator $ORCHESTRATOR_ARGS \
            2>&1 | tee $OUTPUT_DIR/slurm/latest_orchestrator.log $OUTPUT_DIR/slurm/job_${SLURM_JOB_ID}_orchestrator.log &
    fi

    export HF_HUB_OFFLINE=1
    export PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"

    echo $HOSTNAMES_STR | tee $OUTPUT_DIR/slurm/latest_train_node_rank_${TRAIN_NODE_RANK}.log

    uv run torchrun \
        --nnodes=$NUM_TRAIN_NODES \
        --nproc-per-node=$GPUS_PER_NODE \
        --node-rank=$TRAIN_NODE_RANK \
        --rdzv-endpoint=$MASTER_ADDR:$MASTER_PORT \
        --rdzv-id=job_$SLURM_JOB_ID \
        --log-dir=$OUTPUT_DIR/torchrun \
        --tee=3 \
        --redirects=3 \
        --local-ranks-filter=$(seq -s, 0 $((GPUS_PER_NODE - 1))) \
        -m prime_rl.trainer.rl.train \
        @ $CONFIG_DIR/trainer.toml \
        2>&1 | tee -a $OUTPUT_DIR/slurm/latest_train_node_rank_${TRAIN_NODE_RANK}.log $OUTPUT_DIR/slurm/job_${SLURM_JOB_ID}_train_node_rank_${TRAIN_NODE_RANK}.log
    fi
'
