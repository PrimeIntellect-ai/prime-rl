ARG BASE_IMAGE=ghcr.io/primeintellect-ai/hosted-rl/prime-rl:v0.7.1.dev7

FROM ${BASE_IMAGE} AS deepep-builder

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libibverbs-dev \
        librdmacm-dev \
    && rm -rf /var/lib/apt/lists/*

ARG DEEP_EP_COMMIT=29d31c095796f3c8ece47ee9cdcc167051bbeed9
RUN git clone https://github.com/deepseek-ai/DeepEP.git /tmp/DeepEP \
    && git -C /tmp/DeepEP checkout "${DEEP_EP_COMMIT}"

ENV CUDA_HOME=/usr/local/cuda
ENV TORCH_CUDA_ARCH_LIST=10.0
ENV DISABLE_AGGRESSIVE_PTX_INSTRS=1
ENV MAX_JOBS=16

RUN cd /tmp/DeepEP \
    && /app/.venv/bin/python setup.py bdist_wheel --dist-dir /tmp/deepep-wheel

FROM ${BASE_IMAGE}

USER root
COPY --from=deepep-builder /tmp/deepep-wheel/*.whl /tmp/deep_ep.whl
RUN /app/.venv/bin/python -m pip install --no-cache-dir --no-deps /tmp/deep_ep.whl \
    && rm /tmp/deep_ep.whl

USER appuser
